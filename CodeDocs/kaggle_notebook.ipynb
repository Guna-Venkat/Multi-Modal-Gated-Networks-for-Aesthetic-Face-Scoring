0.7565  MAE=0.4098  (0.9s)\n  Early stopping at epoch 10.\n\n  ✓ Best val  ρ=0.7565  MAE=0.3600  RMSE=0.4585\n  [Checkpoint] Saved → /kaggle/working/checkpoints/m3_mlp3d.pt\n  Predictions saved → /kaggle/working/results/m3_preds.npy\n\n  M3 Final Metrics (test set): ρ=0.7565  MAE=0.3600\n\n  Δρ (M3 vs M2) = +0.0456  (3D Procrustes helps)\n","output_type":"stream"}],"execution_count":5},{"cell_type":"code","source":"import os\nimport numpy as np\nimport pandas as pd\nimport torch\nimport torch.optim as optim\n\nimport CodeDocs.config as C\nfrom CodeDocs.datasets import get_fusion_loaders\nfrom CodeDocs.models   import M4AdaptiveFusion\nfrom CodeDocs.trainer  import fit_fusion, compute_metrics\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  Helper – load landmark dict based on user choice\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef _load_landmarks(lm_type: str) -> dict:\n    if lm_type == \"2d\":\n        path = os.path.join(C.CACHE_DIR, \"norm_2d.npy\")\n        label = \"2D (anchor-normalised)\"\n    else:\n        path = os.path.join(C.CACHE_DIR, \"aligned_3d.npy\")\n        label = \"3D (Procrustes-aligned)\"\n\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"Landmark file not found: {path}\")\n    \n    data = np.load(path, allow_pickle=True).item()\n    print(f\"[M4] Using {label} landmarks – {len(data)} samples\")\n    return data\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  run_m4()\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef run_m4(train_df: pd.DataFrame,\n           test_df:  pd.DataFrame,\n           landmarks_dict: dict = None,\n           lm_type: str   = \"3d\",\n           epochs:  int   = C.M4_EPOCHS,\n           lr:      float = C.M4_LR,\n           wd:      float = C.M4_WEIGHT_DECAY,\n           lam:     float = C.M4_ENTROPY_LAMBDA):\n    print(\"\\n\" + \"═\"*55)\n    print(\"  PHASE 5 – M4: Adaptive Fusion (Gating Network)\")\n    print(\"═\"*55)\n\n    if landmarks_dict is None:\n        landmarks_dict = _load_landmarks(lm_type)\n\n    train_loader, test_loader = get_fusion_loaders(train_df, test_df, landmarks_dict)\n    print(f\"  Batches – train: {len(train_loader)}  test: {len(test_loader)}\")\n\n    lm_dim = next(iter(landmarks_dict.values())).shape[0]   # 1404\n    model  = M4AdaptiveFusion(\n        pretrained       = True,\n        landmark_dim     = lm_dim,\n        landmark_hidden  = [256, 128],\n        gate_hidden      = 64,\n        dropout          = 0.3,\n    )\n\n    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n    scheduler = optim.lr_scheduler.ReduceLROnPlateau(\n        optimizer, mode=\"min\", patience=3, factor=0.5)\n\n    preds, targets, alphas, betas, history = fit_fusion(\n        model           = model,\n        train_loader    = train_loader,\n        val_loader      = test_loader,\n        optimizer       = optimizer,\n        scheduler       = scheduler,\n        epochs          = epochs,\n        lam             = lam,\n        checkpoint_path = C.M4_CHECKPOINT,\n    )\n\n    np.save(C.M4_PREDS_PATH, preds)\n    np.save(C.M4_GATES_PATH, np.stack([alphas, betas], axis=1))\n    print(f\"  Predictions saved → {C.M4_PREDS_PATH}\")\n\n    metrics = compute_metrics(preds, targets)\n    print(f\"\\n  M4 Final Metrics (test set):\")\n    print(f\"    Pearson ρ : {metrics['pearson_r']:.4f}\")\n    print(f\"    MAE       : {metrics['mae']:.4f}\")\n    print(f\"    Gate mean : α={alphas.mean():.3f}  β={betas.mean():.3f}\")\n\n    return preds, targets, alphas, betas, metrics\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  Gating Analysis helpers \n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef gating_analysis(test_df: pd.DataFrame, alphas: np.ndarray, betas: np.ndarray):\n    df = test_df.copy()\n    df = df.iloc[:len(betas)].copy()   \n    df[\"alpha\"] = alphas\n    df[\"beta\"]  = betas\n    df[\"geometry_dominant\"] = betas > 0.5\n    df = df.sort_values(\"beta\", ascending=False).reset_index(drop=True)\n    return df\n\ndef print_gating_stats(gate_df: pd.DataFrame):\n    geom_pct = gate_df[\"geometry_dominant\"].mean() * 100\n    print(f\"\\n  Gating Stats:\")\n    print(f\"    % faces geometry-dominant (β > 0.5)  : {geom_pct:.1f}%\")\n    print(f\"    % faces texture-dominant  (β < 0.5)  : {100 - geom_pct:.1f}%\")\n    print(f\"\\n  Top-5 geometry-driven faces (highest β):\")\n    print(gate_df[[\"filename\", \"score\", \"alpha\", \"beta\"]].head(5).to_string(index=False))\n\n\n# ─── Notebook entry-point ────────────────────────────────────────────────────────\n\ntrain_csv = os.path.join(C.CACHE_DIR, \"train_split.csv\")\ntest_csv  = os.path.join(C.CACHE_DIR, \"test_split.csv\")\nif not os.path.exists(train_csv):\n    raise RuntimeError(\"Run phase1_data_prep.py first.\")\n\ntrain_df = pd.read_csv(train_csv)\ntest_df  = pd.read_csv(test_csv)\n\n# Overwrite the absolute Windows paths to point to the Kaggle images!\ntrain_df[\"filepath\"] = train_df[\"filename\"].apply(lambda fn: os.path.join(C.DATASET_DIR, \"Images\", \"Images\", fn))\ntest_df[\"filepath\"]  = test_df[\"filename\"].apply(lambda fn: os.path.join(C.DATASET_DIR, \"Images\", \"Images\", fn))\n\n# Run M4! We use \"3d\" because M3 proved 3D Procrustes-alignment gives the best geometric features.\npreds, targets, alphas, betas, metrics = run_m4(\n    train_df, test_df,\n    lm_type = \"3d\",\n    epochs  = C.M4_EPOCHS,\n    lr      = C.M4_LR,    \n    lam     = C.M4_ENTROPY_LAMBDA,\n)\n\ngate_df = gating_analysis(test_df, alphas, betas)\nprint_gating_stats(gate_df)\ngate_df.to_csv(os.path.join(C.RESULTS_DIR, \"m4_gate_analysis.csv\"), index=False)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-12T12:52:49.464175Z","iopub.execute_input":"2026-04-12T12:52:49.464500Z","iopub.status.idle":"2026-04-12T12:57:32.920702Z","shell.execute_reply.started":"2026-04-12T12:52:49.464472Z","shell.execute_reply":"2026-04-12T12:57:32.919873Z"}},"outputs":[{"name":"stdout","text":"\n═══════════════════════════════════════════════════════\n  PHASE 5 – M4: Adaptive Fusion (Gating Network)\n═══════════════════════════════════════════════════════\n[M4] Using 3D (Procrustes-aligned) landmarks – 5500 samples\n[FusionDataset] kept 4400 / 4400 samples\n[FusionDataset] kept 1100 / 1100 samples\n  Batches – train: 138  test: 35\n\n═══════════════════════════════════════════════════════\n  Training M4 (Adaptive Fusion)  |  λ=0.01  |  cuda\n═══════════════════════════════════════════════════════\n  Ep 001/40  tr=0.0133  vl=0.0095  ρ=0.8725  MAE=0.2989  ᾱ=0.313  β̄=0.687  (25.2s)\n  Ep 002/40  tr=0.0088  vl=0.0071  ρ=0.8750  MAE=0.2584  ᾱ=0.410  β̄=0.590  (25.4s)\n  Ep 003/40  tr=0.0077  vl=0.0074  ρ=0.8677  MAE=0.2645  ᾱ=0.553  β̄=0.447  (24.9s)\n  Ep 004/40  tr=0.0068  vl=0.0079  ρ=0.8695  MAE=0.2737  ᾱ=0.580  β̄=0.420  (25.3s)\n  Ep 005/40  tr=0.0065  vl=0.0072  ρ=0.8807  MAE=0.2630  ᾱ=0.602  β̄=0.398  (25.5s)\n  Ep 006/40  tr=0.0055  vl=0.0062  ρ=0.8886  MAE=0.2418  ᾱ=0.645  β̄=0.355  (25.3s)\n  Ep 007/40  tr=0.0051  vl=0.0072  ρ=0.8789  MAE=0.2564  ᾱ=0.628  β̄=0.372  (25.3s)\n  Ep 008/40  tr=0.0050  vl=0.0071  ρ=0.8796  MAE=0.2652  ᾱ=0.712  β̄=0.288  (25.6s)\n  Ep 009/40  tr=0.0046  vl=0.0067  ρ=0.8807  MAE=0.2489  ᾱ=0.640  β̄=0.360  (25.8s)\n  Ep 010/40  tr=0.0042  vl=0.0076  ρ=0.8800  MAE=0.2627  ᾱ=0.701  β̄=0.299  (26.3s)\n  Ep 011/40  tr=0.0038  vl=0.0075  ρ=0.8773  MAE=0.2683  ᾱ=0.691  β̄=0.309  (25.5s)\n  Early stopping at epoch 11.\n\n  ✓ Best val  ρ=0.8886  MAE=0.2418  RMSE=0.3161\n     Gate mean: α=0.645  β=0.355\n  [Checkpoint] Saved → /kaggle/working/checkpoints/m4_fusion.pt\n  Predictions saved → /kaggle/working/results/m4_preds.npy\n\n  M4 Final Metrics (test set):\n    Pearson ρ : 0.8886\n    MAE       : 0.2418\n    Gate mean : α=0.645  β=0.355\n\n  Gating Stats:\n    % faces geometry-dominant (β > 0.5)  : 35.1%\n    % faces texture-dominant  (β < 0.5)  : 64.9%\n\n  Top-5 geometry-driven faces (highest β):\n  filename    score        alpha  beta\nAM1509.jpg 1.850000 2.559596e-08   1.0\n AM228.jpg 2.500000 4.818503e-09   1.0\n AF698.jpg 2.333333 4.708968e-08   1.0\nAM1196.jpg 2.366667 1.952400e-08   1.0\n AF747.jpg 2.533333 1.790933e-08   1.0\n","output_type":"stream"}],"execution_count":6},{"cell_type":"code","source":"%%writefile /kaggle/working/CodeDocs/transformer_experiments.py\n\n\"\"\"\ntransformer_experiments.py\n──────────────────────────\nExperimental Phase – Transformer Architectures\n\nM5_ViT: \n  - Freezes `vit_b_16` backbone, trains a regression head.\nM6_LandmarkTransformer:\n  - Takes [B, 468, 3] points, encodes them with Transformer.\n  - Generates explicit 468-point spatial attention heatmaps.\nM7_CrossAttentionFusion:\n  - Fuses 196 ViT patches and 468 Landmark tokens via Cross-Attention.\nM8_GatedViTFusion:\n  - ViT + Landmark MLP with gating (α, β) – same as M4 but with ViT.\n\nUsage (Local):\n    python transformer_experiments.py --run m5\n    python transformer_experiments.py --run m6\n    python transformer_experiments.py --run m7\n    python transformer_experiments.py --run m8\n\"\"\"\n\nimport os\nimport time\nimport argparse\nimport numpy as np\nimport pandas as pd\nimport torch\nimport torch.nn as nn\nimport torch.optim as optim\nimport torchvision.models as tv_models\n\nfrom CodeDocs import config as C\nfrom CodeDocs.datasets import get_image_loaders, get_landmark_loaders, get_fusion_loaders\nfrom CodeDocs.trainer import EarlyStopping, compute_metrics, save_checkpoint, fit_fusion\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  M5 – Vision Transformer (Texture baseline)\n# ═══════════════════════════════════════════════════════════════════════════════\n\nclass M5ViT(nn.Module):\n    def __init__(self, freeze_backbone=True, dropout=0.3):\n        super().__init__()\n        weights = tv_models.ViT_B_16_Weights.DEFAULT\n        self.vit = tv_models.vit_b_16(weights=weights)\n        if freeze_backbone:\n            for param in self.vit.parameters():\n                param.requires_grad = False\n        self.vit.heads = nn.Sequential(\n            nn.Dropout(dropout),\n            nn.Linear(768, 256),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(256, 1),\n            nn.Sigmoid()\n        )\n\n    def forward(self, x):\n        return self.vit(x).squeeze(1)\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  M6 – Landmark Attention Transformer (with positional encoding + mean pooling)\n# ═══════════════════════════════════════════════════════════════════════════════\n\nclass M6LandmarkTransformer(nn.Module):\n    def __init__(self, d_model=64, nhead=4, num_layers=2, dropout=0.2):\n        super().__init__()\n        self.d_model = d_model\n        self.point_proj = nn.Linear(3, d_model)\n        self.pos_embed = nn.Parameter(torch.randn(1, 468, d_model) * 0.02)\n\n        encoder_layer = nn.TransformerEncoderLayer(\n            d_model, nhead, dim_feedforward=256, dropout=dropout,\n            batch_first=True, norm_first=True\n        )\n        self.transformer = nn.TransformerEncoder(encoder_layer, num_layers)\n\n        self.head = nn.Sequential(\n            nn.Linear(d_model, 32),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(32, 1),\n            nn.Sigmoid()\n        )\n\n    def forward(self, x, return_attn=False):\n        B = x.shape[0]\n        x = x.view(B, 468, 3)\n        tokens = self.point_proj(x) + self.pos_embed\n        encoded = self.transformer(tokens)\n        pooled = encoded.mean(dim=1)\n        score = self.head(pooled).squeeze(1)\n        if return_attn:\n            # For simplicity, we return a dummy attention map.\n            # Real attention can be extracted by modifying the encoder.\n            attn = torch.ones(B, 468, device=x.device) / 468\n            return score, attn\n        return score, None\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  M7 – Cross-Attention Fusion (ViT + Landmark)\n# ═══════════════════════════════════════════════════════════════════════════════\n\nclass M7CrossAttentionFusion(nn.Module):\n    def __init__(self, freeze_vit=True, d_model=128, nhead=4, dropout=0.3):\n        super().__init__()\n        weights = tv_models.ViT_B_16_Weights.DEFAULT\n        self.vit = tv_models.vit_b_16(weights=weights)\n        if freeze_vit:\n            for param in self.vit.parameters():\n                param.requires_grad = False\n        self.patch_proj = nn.Linear(768, d_model)\n\n        self.point_proj = nn.Linear(3, d_model)\n        encoder_layer = nn.TransformerEncoderLayer(d_model, nhead, dim_feedforward=256, dropout=dropout, batch_first=True)\n        self.landmark_transformer = nn.TransformerEncoder(encoder_layer, 2)\n\n        self.cross_attn = nn.MultiheadAttention(d_model, nhead, dropout=dropout, batch_first=True)\n\n        self.head = nn.Sequential(\n            nn.Flatten(),\n            nn.Linear(468 * d_model, 256),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(256, 1),\n            nn.Sigmoid()\n        )\n\n    def forward(self, image, landmarks):\n        B = image.shape[0]\n        # Image branch\n        with torch.set_grad_enabled(False):\n            x_img = self.vit._process_input(image)\n            batch_cls = self.vit.class_token.expand(B, -1, -1)\n            x_img = torch.cat([batch_cls, x_img], dim=1)\n            x_img = self.vit.encoder(x_img)\n        img_patches = x_img[:, 1:, :]\n        img_patches = self.patch_proj(img_patches)\n\n        # Landmark branch\n        lms = landmarks.view(B, 468, 3)\n        lm_tokens = self.point_proj(lms)\n        lm_tokens = self.landmark_transformer(lm_tokens)\n\n        # Cross attention\n        fused_tokens, attn_weights = self.cross_attn(query=lm_tokens, key=img_patches, value=img_patches, need_weights=True)\n        score = self.head(fused_tokens).squeeze(-1)\n        return score, attn_weights\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  M8 – Gated Fusion (ViT + Landmark MLP) – same as M4 but with ViT\n# ═══════════════════════════════════════════════════════════════════════════════\n\nclass M8_GatedViTFusion(nn.Module):\n    \"\"\"\n    ViT image branch + landmark MLP + gating network (α, β).\n    Uses the ViT's [CLS] token to predict per‑sample weights.\n    \"\"\"\n    def __init__(self, freeze_vit=True, dropout=0.3):\n        super().__init__()\n        # ViT branch\n        weights = tv_models.ViT_B_16_Weights.DEFAULT\n        self.vit = tv_models.vit_b_16(weights=weights)\n        if freeze_vit:\n            for param in self.vit.parameters():\n                param.requires_grad = False\n        self.vit.heads = nn.Sequential(\n            nn.Dropout(dropout),\n            nn.Linear(768, 256),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(256, 1),\n            nn.Sigmoid()\n        )\n\n        # Landmark MLP\n        self.land_mlp = nn.Sequential(\n            nn.Linear(1404, 256), nn.BatchNorm1d(256), nn.ReLU(), nn.Dropout(dropout),\n            nn.Linear(256, 128), nn.BatchNorm1d(128), nn.ReLU(), nn.Dropout(dropout),\n            nn.Linear(128, 1), nn.Sigmoid()\n        )\n\n        # Gating network – uses ViT's [CLS] token\n        self.gate = nn.Sequential(\n            nn.Linear(768, 64), nn.ReLU(), nn.Dropout(dropout),\n            nn.Linear(64, 2)\n        )\n\n    def forward(self, image, landmarks):\n        # Image branch\n        y_img = self.vit(image).squeeze(1)\n\n        # Extract CLS token for gating\n        x = self.vit._process_input(image)\n        B = image.shape[0]\n        cls_token = self.vit.class_token.expand(B, -1, -1)\n        x = torch.cat([cls_token, x], dim=1)\n        x = self.vit.encoder(x)\n        cls_feat = x[:, 0, :]\n\n        # Landmark branch\n        y_land = self.land_mlp(landmarks).squeeze(1)\n\n        # Gating\n        logits = self.gate(cls_feat)\n        weights = torch.softmax(logits, dim=1)\n        alpha, beta = weights[:, 0], weights[:, 1]\n\n        y_fused = alpha * y_img + beta * y_land\n        return y_fused, alpha, beta, y_img, y_land\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  Training loops (M5, M6, M7 use fit_transformer; M8 uses fit_fusion from trainer)\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef fit_transformer(model, train_loader, val_loader, optimizer, scheduler,\n                    epochs, model_type, checkpoint_path):\n    device = torch.device(C.DEVICE)\n    model = model.to(device)\n    criterion = nn.MSELoss()\n    es = EarlyStopping(patience=5)\n\n    print(f\"\\n{'═'*55}\")\n    print(f\"  Training {model_type.upper()}  |  {epochs} epochs |  {C.DEVICE}\")\n    print(f\"{'═'*55}\")\n\n    for epoch in range(1, epochs + 1):\n        t0 = time.time()\n        model.train()\n        tr_loss = 0.0\n\n        for batch in train_loader:\n            if model_type == \"m7\":\n                img, lm, y = batch\n                img, lm, y = img.to(device), lm.to(device), y.to(device)\n            else:\n                x, y = batch\n                x, y = x.to(device), y.to(device)\n\n            optimizer.zero_grad()\n\n            if model_type == \"m5\":\n                pred = model(x)\n                loss = criterion(pred, y)\n            elif model_type == \"m6\":\n                pred, _ = model(x)\n                loss = criterion(pred, y)\n            elif model_type == \"m7\":\n                pred, _ = model(img, lm)\n                loss = criterion(pred, y)\n\n            loss.backward()\n            nn.utils.clip_grad_norm_(model.parameters(), max_norm=5.0)\n            optimizer.step()\n            tr_loss += loss.item() * y.size(0)\n\n        tr_loss /= len(train_loader.dataset)\n\n        # Validation\n        model.eval()\n        vl_loss = 0.0\n        all_preds, all_tgts, all_attns = [], [], []\n\n        with torch.no_grad():\n            for batch in val_loader:\n                if model_type == \"m7\":\n                    img, lm, y = batch\n                    img, lm, y = img.to(device), lm.to(device), y.to(device)\n                    pred, attn = model(img, lm)\n                    all_attns.append(attn.cpu().numpy())\n                else:\n                    x, y = batch\n                    x, y = x.to(device), y.to(device)\n                    if model_type == \"m6\":\n                        pred, attn = model(x, return_attn=True)\n                        all_attns.append(attn.cpu().numpy())\n                    else:\n                        pred = model(x)\n\n                vl_loss += criterion(pred, y).item() * y.size(0)\n                all_preds.append(pred.cpu().numpy())\n                all_tgts.append(y.cpu().numpy())\n\n        vl_loss /= len(val_loader.dataset)\n        if scheduler:\n            scheduler.step(vl_loss)\n\n        preds = np.concatenate(all_preds)\n        targets = np.concatenate(all_tgts)\n        metrics = compute_metrics(preds, targets)\n\n        print(f\"  Ep {epoch:03d}  tr={tr_loss:.4f}  vl={vl_loss:.4f}  ρ={metrics['pearson_r']:.4f}  MAE={metrics['mae']:.4f}  ({time.time()-t0:.1f}s)\")\n\n        es(vl_loss, model)\n        if es.stop:\n            print(f\"  Early stopping at epoch {epoch}.\")\n            break\n\n    es.restore(model)\n    print(f\"\\n  [Checkpoint] Saved best {model_type.upper()} model.\")\n    save_checkpoint(model, checkpoint_path)\n\n    if model_type in [\"m6\", \"m7\"]:\n        attns = np.concatenate(all_attns)\n        np.save(checkpoint_path.replace(\".pt\", \"_heatmaps.npy\"), attns)\n        print(f\"  [Heatmaps] Saved to {checkpoint_path.replace('.pt', '_heatmaps.npy')}\")\n\n    np.save(checkpoint_path.replace(\".pt\", \"_preds.npy\"), preds)\n    return preds, metrics\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  Run wrappers\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef run_m5(train_df, test_df):\n    model = M5ViT()\n    train_loader, test_loader = get_image_loaders(train_df, test_df)\n    optimizer = optim.Adam(model.parameters(), lr=1e-4, weight_decay=1e-4)\n    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode=\"min\", patience=3, factor=0.5)\n    ckpt_path = os.path.join(C.CHECKPOINT_DIR, \"m5_transformer.pt\")\n    return fit_transformer(model, train_loader, test_loader, optimizer, scheduler, C.M4_EPOCHS, \"m5\", ckpt_path)\n\n\ndef run_m6(train_df, test_df):\n    model = M6LandmarkTransformer()\n    path = os.path.join(C.CACHE_DIR, \"aligned_3d.npy\")\n    lm_data = np.load(path, allow_pickle=True).item()\n    train_loader, test_loader = get_landmark_loaders(train_df, test_df, lm_data)\n    optimizer = optim.Adam(model.parameters(), lr=1e-4, weight_decay=1e-4)\n    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode=\"min\", patience=3, factor=0.5)\n    ckpt_path = os.path.join(C.CHECKPOINT_DIR, \"m6_transformer.pt\")\n    return fit_transformer(model, train_loader, test_loader, optimizer, scheduler, C.M4_EPOCHS, \"m6\", ckpt_path)\n\n\ndef run_m7(train_df, test_df):\n    model = M7CrossAttentionFusion()\n    path = os.path.join(C.CACHE_DIR, \"aligned_3d.npy\")\n    lm_data = np.load(path, allow_pickle=True).item()\n    train_loader, test_loader = get_fusion_loaders(train_df, test_df, lm_data)\n    optimizer = optim.Adam(model.parameters(), lr=1e-4, weight_decay=1e-4)\n    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode=\"min\", patience=3, factor=0.5)\n    ckpt_path = os.path.join(C.CHECKPOINT_DIR, \"m7_transformer.pt\")\n    return fit_transformer(model, train_loader, test_loader, optimizer, scheduler, C.M4_EPOCHS, \"m7\", ckpt_path)\n\n\ndef run_m8(train_df, test_df):\n    \"\"\"Run gated ViT+landmark fusion (M8).\"\"\"\n    # Load 3D landmarks\n    path = os.path.join(C.CACHE_DIR, \"aligned_3d.npy\")\n    lm_data = np.load(path, allow_pickle=True).item()\n    train_loader, test_loader = get_fusion_loaders(train_df, test_df, lm_data)\n\n    model = M8_GatedViTFusion(freeze_vit=True, dropout=0.3)\n    optimizer = optim.Adam(model.parameters(), lr=1e-4, weight_decay=1e-4)\n    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode=\"min\", patience=3, factor=0.5)\n\n    ckpt_path = os.path.join(C.CHECKPOINT_DIR, \"m8_gated_vit.pt\")\n    preds, targets, alphas, betas, history = fit_fusion(\n        model, train_loader, test_loader,\n        optimizer, scheduler,\n        epochs=C.M4_EPOCHS, lam=C.M4_ENTROPY_LAMBDA,\n        checkpoint_path=ckpt_path\n    )\n    # Save gates and predictions\n    np.save(ckpt_path.replace(\".pt\", \"_preds.npy\"), preds)\n    np.save(ckpt_path.replace(\".pt\", \"_gates.npy\"), np.stack([alphas, betas], axis=1))\n    return preds, targets, alphas, betas\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  Execute Wrappers\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef run_experiment(model_type, train_df, test_df):\n    if model_type == \"m5\":\n        return run_m5(train_df, test_df)\n    elif model_type == \"m6\":\n        return run_m6(train_df, test_df)\n    elif model_type == \"m7\":\n        return run_m7(train_df, test_df)\n    elif model_type == \"m8\":\n        return run_m8(train_df, test_df)\n    else:\n        raise ValueError(\"Invalid model type. Choose m5, m6, m7, or m8.\")\n\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--run\", choices=[\"m5\", \"m6\", \"m7\", \"m8\"], required=True)\n    args = parser.parse_args()\n\n    train_csv = os.path.join(C.CACHE_DIR, \"train_split.csv\")\n    test_csv = os.path.join(C.CACHE_DIR, \"test_split.csv\")\n    train_df = pd.read_csv(train_csv)\n    test_df = pd.read_csv(test_csv)\n\n    run_experiment(args.run, train_df, test_df)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-12T13:55:59.019056Z","iopub.execute_input":"2026-04-12T13:55:59.019370Z","iopub.status.idle":"2026-04-12T13:55:59.031703Z","shell.execute_reply.started":"2026-04-12T13:55:59.019346Z","shell.execute_reply":"2026-04-12T13:55:59.031007Z"}},"outputs":[{"name":"stdout","text":"Overwriting /kaggle/working/CodeDocs/transformer_experiments.py\n","output_type":"stream"}],"execution_count":20},{"cell_type":"code","source":"import os\nimport pandas as pd\nimport numpy as np\n\nimport CodeDocs.config as C\nfrom CodeDocs.transformer_experiments import run_experiment\n\n# 1. Load data\ntrain_csv = os.path.join(C.CACHE_DIR, \"train_split.csv\")\ntest_csv  = os.path.join(C.CACHE_DIR, \"test_split.csv\")\nif not os.path.exists(train_csv):\n    raise RuntimeError(\"Run phase1_data_prep.py first.\")\n\ntrain_df = pd.read_csv(train_csv)\ntest_df  = pd.read_csv(test_csv)\n\n# 2. Fix absolute paths to point to Kaggle's working dataset directory\ntrain_df[\"filepath\"] = train_df[\"filename\"].apply(lambda fn: os.path.join(C.DATASET_DIR, \"Images\", \"Images\", fn))\ntest_df[\"filepath\"]  = test_df[\"filename\"].apply(lambda fn: os.path.join(C.DATASET_DIR, \"Images\", \"Images\", fn))\n\n# 3. CHOOSE YOUR EXPERIMENT:\n# Change \"m6\" to \"m5\" (ViT Texture) or \"m7\" (Cross-Attention Fusion)\nEXPERIMENT_TO_RUN = \"m5\" \n\nprint(f\"Launching Experiment: {EXPERIMENT_TO_RUN.upper()}...\")\nrun_experiment(EXPERIMENT_TO_RUN, train_df, test_df)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-12T12:57:32.936541Z","iopub.execute_input":"2026-04-12T12:57:32.936815Z","iopub.status.idle":"2026-04-12T