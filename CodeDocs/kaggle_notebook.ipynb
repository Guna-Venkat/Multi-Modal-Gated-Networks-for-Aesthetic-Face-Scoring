mage_model = True,\n    )\n\n    # ── Save predictions ─────────────────────────────────────\n    np.save(C.M1_PREDS_PATH, preds)\n    print(f\"  Predictions saved → {C.M1_PREDS_PATH}\")\n\n    metrics = compute_metrics(preds, targets)\n    print(f\"\\n  M1 Final Metrics (test set):\")\n    print(f\"    Pearson ρ : {metrics['pearson_r']:.4f}\")\n    print(f\"    MAE       : {metrics['mae']:.4f}  (1-5 scale)\")\n    print(f\"    RMSE      : {metrics['rmse']:.4f}\")\n\n    return preds, targets, metrics\n\n# ─── Notebook entry-point ────────────────────────────────────────────────────────\n# Load cached splits (created by phase1)\ntrain_csv = os.path.join(C.CACHE_DIR, \"train_split.csv\")\ntest_csv  = os.path.join(C.CACHE_DIR, \"test_split.csv\")\n\nif not os.path.exists(train_csv):\n    raise RuntimeError(\"Run phase1_data_prep.py first to create data splits.\")\n\ntrain_df = pd.read_csv(train_csv)\ntest_df  = pd.read_csv(test_csv)\n\n# OVERWRITE the Windows paths with the Kaggle paths for the images!\ntrain_df[\"filepath\"] = train_df[\"filename\"].apply(lambda fn: os.path.join(C.DATASET_DIR, \"Images\", \"Images\", fn))\ntest_df[\"filepath\"]  = test_df[\"filename\"].apply(lambda fn: os.path.join(C.DATASET_DIR, \"Images\", \"Images\", fn))\n\n# Now run the model!\npreds, targets, metrics = run_m1(train_df, test_df, epochs=C.M1_EPOCHS, lr=C.M1_LR, wd=C.M1_WEIGHT_DECAY)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-12T12:47:31.795629Z","iopub.execute_input":"2026-04-12T12:47:31.796071Z","iopub.status.idle":"2026-04-12T12:52:26.062479Z","shell.execute_reply.started":"2026-04-12T12:47:31.796036Z","shell.execute_reply":"2026-04-12T12:52:26.061538Z"}},"outputs":[{"name":"stdout","text":"\n═══════════════════════════════════════════════════════\n  PHASE 2 – M1: Full-Image CNN (ResNet-18)\n═══════════════════════════════════════════════════════\n  Batches – train: 138  test: 35\n\n═══════════════════════════════════════════════════════\n  Training M1-CNN  |  30 epochs max  |  cuda\n═══════════════════════════════════════════════════════\n  Ep 001/30  tr=0.0196  vl=0.0083  ρ=0.8522  MAE=0.2752  (35.6s)\n  Ep 002/30  tr=0.0110  vl=0.0155  ρ=0.8478  MAE=0.4049  (25.5s)\n  Ep 003/30  tr=0.0089  vl=0.0100  ρ=0.8549  MAE=0.3190  (25.4s)\n  Ep 004/30  tr=0.0087  vl=0.0200  ρ=0.8117  MAE=0.4516  (25.1s)\n  Ep 005/30  tr=0.0082  vl=0.0113  ρ=0.8429  MAE=0.3290  (24.9s)\n  Ep 006/30  tr=0.0068  vl=0.0065  ρ=0.8857  MAE=0.2399  (25.0s)\n  Ep 007/30  tr=0.0061  vl=0.0073  ρ=0.8713  MAE=0.2590  (25.1s)\n  Ep 008/30  tr=0.0065  vl=0.0078  ρ=0.8698  MAE=0.2657  (25.2s)\n  Ep 009/30  tr=0.0064  vl=0.0090  ρ=0.8510  MAE=0.2842  (25.1s)\n  Ep 010/30  tr=0.0064  vl=0.0083  ρ=0.8643  MAE=0.2828  (25.3s)\n  Ep 011/30  tr=0.0051  vl=0.0068  ρ=0.8813  MAE=0.2511  (24.8s)\n  Early stopping at epoch 11.\n\n  ✓ Best val  ρ=0.8857  MAE=0.2399  RMSE=0.3218\n  [Checkpoint] Saved → /kaggle/working/checkpoints/m1_cnn.pt\n  Predictions saved → /kaggle/working/results/m1_preds.npy\n\n  M1 Final Metrics (test set):\n    Pearson ρ : 0.8857\n    MAE       : 0.2399  (1-5 scale)\n    RMSE      : 0.3218\n","output_type":"stream"}],"execution_count":4},{"cell_type":"code","source":"import os\nimport pickle\nimport numpy as np\nimport pandas as pd\nimport torch\nimport torch.optim as optim\n\nimport CodeDocs.config as C\nfrom CodeDocs.datasets import get_landmark_loaders\nfrom CodeDocs.models   import LandmarkMLP\nfrom CodeDocs.trainer  import fit, compute_metrics\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  Helper – load pre-computed landmark dicts\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef _load_lm2d_norm() -> dict:\n    path = os.path.join(C.CACHE_DIR, \"norm_2d.npy\")\n    if not os.path.exists(path):\n        raise FileNotFoundError(\"Normalised 2D landmarks not found at \" + path)\n    data = np.load(path, allow_pickle=True).item()\n    print(f\"[M2] Loaded 2D landmarks: {len(data)} samples\")\n    return data\n\ndef _load_lm3d_aligned() -> dict:\n    path = os.path.join(C.CACHE_DIR, \"aligned_3d.npy\")\n    if not os.path.exists(path):\n        raise FileNotFoundError(\"Aligned 3D landmarks not found at \" + path)\n    data = np.load(path, allow_pickle=True).item()\n    print(f\"[M3] Loaded 3D landmarks: {len(data)} samples\")\n    return data\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  run_m2() – Phase 3\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef run_m2(train_df: pd.DataFrame,\n           test_df:  pd.DataFrame,\n           lm2d_norm: dict = None,\n           epochs: int   = C.M2_EPOCHS,\n           lr:     float = C.M2_LR,\n           wd:     float = C.M2_WEIGHT_DECAY):\n    print(\"\\n\" + \"═\"*55)\n    print(\"  PHASE 3 – M2: 2D Landmarks + Anchor Norm + MLP\")\n    print(\"═\"*55)\n\n    if lm2d_norm is None:\n        lm2d_norm = _load_lm2d_norm()\n\n    train_loader, test_loader = get_landmark_loaders(train_df, test_df, lm2d_norm)\n    print(f\"  Batches – train: {len(train_loader)}  test: {len(test_loader)}\")\n\n    model     = LandmarkMLP(input_dim=C.LANDMARK_DIM_3D, hidden_dims=C.M2_HIDDEN)\n    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n    scheduler = optim.lr_scheduler.ReduceLROnPlateau(\n        optimizer, mode=\"min\", patience=3, factor=0.5\n    )\n\n    preds, targets, history = fit(\n        model           = model,\n        train_loader    = train_loader,\n        val_loader      = test_loader,\n        optimizer       = optimizer,\n        scheduler       = scheduler,\n        epochs          = epochs,\n        checkpoint_path = C.M2_CHECKPOINT,\n        model_name      = \"M2-MLP-2D\",\n        is_image_model  = False,\n    )\n\n    np.save(C.M2_PREDS_PATH, preds)\n    print(f\"  Predictions saved → {C.M2_PREDS_PATH}\")\n    metrics = compute_metrics(preds, targets)\n    print(f\"\\n  M2 Final Metrics (test set): ρ={metrics['pearson_r']:.4f}  MAE={metrics['mae']:.4f}\")\n    return preds, targets, metrics\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n#  run_m3() – Phase 4  \n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef run_m3(train_df: pd.DataFrame,\n           test_df:  pd.DataFrame,\n           lm3d_aligned: dict = None,\n           epochs: int   = C.M3_EPOCHS,\n           lr:     float = C.M3_LR,\n           wd:     float = C.M3_WEIGHT_DECAY):\n    print(\"\\n\" + \"═\"*55)\n    print(\"  PHASE 4 – M3: 3D Landmarks + Procrustes + MLP\")\n    print(\"═\"*55)\n\n    if lm3d_aligned is None:\n        lm3d_aligned = _load_lm3d_aligned()\n\n    train_loader, test_loader = get_landmark_loaders(train_df, test_df, lm3d_aligned)\n    print(f\"  Batches – train: {len(train_loader)}  test: {len(test_loader)}\")\n\n    model     = LandmarkMLP(input_dim=C.LANDMARK_DIM_3D, hidden_dims=C.M3_HIDDEN)\n    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n    scheduler = optim.lr_scheduler.ReduceLROnPlateau(\n        optimizer, mode=\"min\", patience=3, factor=0.5\n    )\n\n    preds, targets, history = fit(\n        model           = model,\n        train_loader    = train_loader,\n        val_loader      = test_loader,\n        optimizer       = optimizer,\n        scheduler       = scheduler,\n        epochs          = epochs,\n        checkpoint_path = C.M3_CHECKPOINT,\n        model_name      = \"M3-MLP-3D\",\n        is_image_model  = False,\n    )\n\n    np.save(C.M3_PREDS_PATH, preds)\n    print(f\"  Predictions saved → {C.M3_PREDS_PATH}\")\n    metrics = compute_metrics(preds, targets)\n    print(f\"\\n  M3 Final Metrics (test set): ρ={metrics['pearson_r']:.4f}  MAE={metrics['mae']:.4f}\")\n    return preds, targets, metrics\n\ndef compare_m2_m3(metrics_m2: dict, metrics_m3: dict):\n    delta = metrics_m3[\"pearson_r\"] - metrics_m2[\"pearson_r\"]\n    print(f\"\\n  Δρ (M3 vs M2) = {delta:+.4f}  ({'3D Procrustes helps' if delta > 0 else '3D Procrustes does NOT help'})\")\n\n\n# ─── Notebook entry-point ────────────────────────────────────────────────────────\ntrain_csv = os.path.join(C.CACHE_DIR, \"train_split.csv\")\ntest_csv  = os.path.join(C.CACHE_DIR, \"test_split.csv\")\nif not os.path.exists(train_csv):\n    raise RuntimeError(\"Run phase1_data_prep.py first.\")\n\ntrain_df = pd.read_csv(train_csv)\ntest_df  = pd.read_csv(test_csv)\n\n# Run M2\n_, _, m2_metrics = run_m2(train_df, test_df, epochs=C.M2_EPOCHS, lr=C.M2_LR)\n\n# Run M3\n_, _, m3_metrics = run_m3(train_df, test_df, epochs=C.M3_EPOCHS, lr=C.M3_LR)\n\n# Compare them!\ncompare_m2_m3(m2_metrics, m3_metrics)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-12T12:52:26.064366Z","iopub.execute_input":"2026-04-12T12:52:26.064708Z","iopub.status.idle":"2026-04-12T12:52:49.462859Z","shell.execute_reply.started":"2026-04-12T12:52:26.064677Z","shell.execute_reply":"2026-04-12T12:52:49.462092Z"}},"outputs":[{"name":"stdout","text":"\n═══════════════════════════════════════════════════════\n  PHASE 3 – M2: 2D Landmarks + Anchor Norm + MLP\n═══════════════════════════════════════════════════════\n[M2] Loaded 2D landmarks: 5500 samples\n[LandmarkDataset] kept 4400 / 4400 samples\n[LandmarkDataset] kept 1100 / 1100 samples\n  Batches – train: 138  test: 35\n\n═══════════════════════════════════════════════════════\n  Training M2-MLP-2D  |  50 epochs max  |  cuda\n═══════════════════════════════════════════════════════\n  Ep 001/50  tr=0.0227  vl=0.0385  ρ=0.5440  MAE=0.6535  (0.9s)\n  Ep 002/50  tr=0.0176  vl=0.0270  ρ=0.6374  MAE=0.5481  (0.9s)\n  Ep 003/50  tr=0.0160  vl=0.0179  ρ=0.6865  MAE=0.4146  (0.9s)\n  Ep 004/50  tr=0.0155  vl=0.0826  ρ=0.6128  MAE=1.0033  (0.9s)\n  Ep 005/50  tr=0.0152  vl=0.0487  ρ=0.6384  MAE=0.7567  (0.8s)\n  Ep 006/50  tr=0.0147  vl=0.0160  ρ=0.6942  MAE=0.3987  (0.9s)\n  Ep 007/50  tr=0.0146  v